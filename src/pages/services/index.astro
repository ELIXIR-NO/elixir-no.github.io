---
import { getCollection } from "astro:content";
import Page from "../../layouts/page.astro";
import ListingFilters from "../../components/listing-filters";
import { slugToTitleCase, idToSlug, resolveContentAsset } from "../../lib/utils";

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const services = (await getCollection("services")).sort((a, b) => a.data.title.localeCompare(b.data.title));

// Build tag list with counts
const tagCounts = new Map<string, number>();
services.forEach(s => (s.data.tags ?? []).forEach(t => tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1)));
const tags = [...tagCounts.entries()]
    .sort((a, b) => b[1] - a[1])
    .map(([id, count]) => ({ id, label: slugToTitleCase(id), count }));
---

<Page variant="wide" seo={{
    title: "Services",
    description: "Bioinformatics tools and infrastructure for life science research — data management, analysis, storage, and compute services provided by ELIXIR Norway.",
}}>

    <!-- Hero -->
    <div class="max-w-3xl">
        <p class="text-sm font-semibold text-accent tracking-wide uppercase">Services</p>
        <h1 class="mt-3 text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-brand-primary dark:text-white leading-[1.15]">
            Tools and infrastructure for life science research
        </h1>
        <p class="mt-6 text-base sm:text-lg leading-relaxed text-brand-grey dark:text-gray-300 max-w-2xl">
            ELIXIR Norway provides software tools, databases, storage and compute infrastructure
            to support life science researchers across Norway and internationally.
        </p>
        <a
            href={`${BASE}/services/status`}
            class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-accent transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:rounded"
        >
            <span class="relative flex h-2 w-2 shrink-0">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
            </span>
            Check live service status
        </a>
    </div>

    <!-- Filter -->
    <div class="mt-10">
        <ListingFilters client:load groups={[{ key: 'tags', label: 'Tags', options: tags, mode: 'multi' }]} event="tags-changed" />
    </div>

    <!-- Service grid -->
    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="services-grid" aria-live="polite">
        {services.map((service) => {
            const slug = idToSlug(service.id);
            const logo = service.data.logo ? resolveContentAsset(`${service.collection}/${service.id}`, service.data.logo) : null;
            const serviceTags = service.data.tags ?? [];
            const isNodeService = serviceTags.includes('service');
            const hasWebsite = !!service.data.website;
            return (
                <a
                    href={`${BASE}/services/${slug}`}
                    class="service-card group relative flex flex-col rounded-2xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.02] overflow-hidden transition-[border-color,box-shadow] duration-200 hover:border-accent/40 hover:shadow-[0_0_0_1px_rgb(var(--color-accent)/0.15),0_4px_20px_-4px_rgb(var(--color-accent)/0.1)] focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 dark:focus-visible:ring-offset-dark-background"
                    data-tags={serviceTags.join(',')}
                >
                    {/* Logo banner — light bg in both modes so logos with baked-in white backgrounds blend cleanly */}
                    <div class="relative flex items-center justify-center h-32 bg-gradient-to-br from-gray-50 via-gray-50 to-gray-100/80 dark:from-gray-100 dark:via-gray-50 dark:to-white border-b border-gray-200/40 dark:border-gray-200/20">
                        {isNodeService && (
                            <span class="absolute top-2.5 right-2.5 rounded-full bg-accent/10 border border-accent/20 px-2.5 py-0.5 text-xs font-bold tracking-wide text-accent">
                                Node service
                            </span>
                        )}
                        {logo ? (
                            <img
                                src={logo}
                                alt=""
                                aria-hidden="true"
                                class="max-h-16 max-w-[70%] object-contain drop-shadow-sm"
                                loading="lazy"
                            />
                        ) : (
                            <div class="h-12 w-12 rounded-xl bg-accent/10 flex items-center justify-center" aria-hidden="true">
                                <span class="text-lg font-bold text-accent">{service.data.title.charAt(0)}</span>
                            </div>
                        )}
                    </div>

                    {/* Content */}
                    <div class="flex flex-col flex-1 p-5">
                        {/* Title */}
                        <h2 class="text-[15px] font-semibold text-brand-primary dark:text-white group-hover:text-accent transition-colors leading-snug">
                            {service.data.title}
                        </h2>

                        {/* Summary */}
                        <p class="mt-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400 line-clamp-2 flex-1">
                            {service.data.summary}
                        </p>

                        {/* Tags */}
                        {serviceTags.length > 0 && (
                            <div class="mt-3.5 flex flex-wrap gap-1.5">
                                {serviceTags.filter(t => t !== 'service').slice(0, 3).map(tag => (
                                    <span class="rounded-md bg-gray-100 dark:bg-white/[0.06] px-2 py-0.5 text-xs font-medium text-gray-600 dark:text-gray-400">
                                        {slugToTitleCase(tag)}
                                    </span>
                                ))}
                            </div>
                        )}

                        {/* Footer */}
                        <div class="mt-4 pt-3.5 border-t border-gray-100 dark:border-gray-800/50 flex items-center justify-between">
                            <span class="flex items-center gap-1.5 text-xs font-medium text-gray-500 dark:text-gray-400 group-hover:text-accent transition-colors">
                                Learn more
                                <svg class="h-3 w-3 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                                </svg>
                            </span>
                            {hasWebsite && (
                                <span class="flex items-center gap-1 text-xs font-medium text-gray-500 dark:text-gray-400">
                                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A8.966 8.966 0 0 1 3 12c0-1.97.633-3.794 1.708-5.278" />
                                    </svg>
                                    Web
                                </span>
                            )}
                        </div>
                    </div>
                </a>
            );
        })}
    </div>

    <!-- Filtering script -->
    <script is:inline>
        window.addEventListener('tags-changed', function(e) {
            var detail = e.detail || {};
            var tagsSet = detail['tags'];
            var noTags = !tagsSet || tagsSet.size === 0;
            document.querySelectorAll('.service-card').forEach(function(card) {
                if (noTags) { card.style.display = ''; return; }
                var cardTags = (card.getAttribute('data-tags') || '').split(',');
                var match = false;
                tagsSet.forEach(function(t) { if (cardTags.indexOf(t) !== -1) match = true; });
                card.style.display = match ? '' : 'none';
            });
        });
    </script>

</Page>
